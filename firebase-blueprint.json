{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "annotator", "reviewer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A collection of images to be annotated",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Image": {
      "title": "Image",
      "description": "An image within a project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "annotating", "reviewed", "completed"] },
        "projectId": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "url", "projectId", "status"]
    },
    "Annotation": {
      "title": "Annotation",
      "description": "A single annotation (bbox, polygon, etc.)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["bbox", "polygon", "keypoint"] },
        "label": { "type": "string" },
        "points": { "type": "array", "items": { "type": "number" } },
        "metadata": { "type": "object" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "label", "points"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects"
    },
    "/projects/{projectId}/images/{imageId}": {
      "schema": "Image",
      "description": "Images in a project"
    },
    "/projects/{projectId}/images/{imageId}/annotations/{annotationId}": {
      "schema": "Annotation",
      "description": "Annotations for an image"
    }
  }
}
